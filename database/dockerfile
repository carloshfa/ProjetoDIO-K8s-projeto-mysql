# Dockerfile do banco de dados MySQL.
# Usa a imagem oficial MySQL 5.7 e inicializa o esquema com sql.sql.
FROM mysql:5.7

WORKDIR /var/lib/mysql/

# Define variáveis de ambiente para a inicialização do MySQL.
ENV MYSQL_ROOT_PASSWORD=Senha123
ENV MYSQL_DATABASE=meubanco

# Copia o script SQL para o diretório de inicialização do container.
COPY sql.sql /docker-entrypoint-initdb.d/

# Expõe a porta 3306 utilizada pelo MySQL.
EXPOSE 3306
